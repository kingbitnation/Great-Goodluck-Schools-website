generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ AUTHENTICATION & AUTHORIZATION ============
model User {
  id                    String   @id @default(uuid())
  email                 String   @unique
  password              String
  firstName             String
  lastName              String
  phone                 String?
  avatar                String?
  roleId                String
  role                  Role     @relation(fields: [roleId], references: [id])
  schoolId              String?
  school                School?  @relation(fields: [schoolId], references: [id])
  isActive              Boolean  @default(true)
  emailVerified         Boolean  @default(false)
  emailVerifiedAt       DateTime?
  failedLoginAttempts   Int      @default(0)
  lockedUntil           DateTime?
  lastLogin             DateTime?
  twoFactorEnabled      Boolean  @default(false)
  twoFactorSecret       String?
  sessionTokens         String[] @default([])
  refreshTokens         RefreshToken[]
  authTokens            AuthToken[]
  loginHistory          LoginHistory[]
  twoFactorBackupCodes  TwoFactorBackupCode[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relationships
  student               Student?
  teacher               Teacher?
  parent                Parent?
  accountant            Accountant?
  librarian             Librarian?
  hostelManager         HostelManager?
  transportManager      TransportManager?
  biometricManager      BiometricManager?
  hrManager             HrManager?
  employee              Employee?
  alumniProfile         AlumniProfile?
  marketplaceCartItems  MarketplaceCartItem[]
  marketplaceOrders     MarketplaceOrder[]
  auditLogs             AuditLog[]
  supportTickets        SupportTicket[]
  assignedTickets       SupportTicket[] @relation("TicketAssignee")
  supportMessages       SupportTicketMessage[]
  reviewedPayments      Payment[] @relation("PaymentReviewer")
  paymentVerificationLogs PaymentVerificationLog[]
  
  // Messages & notifications
  sentMessages          Message[] @relation("sender")
  receivedMessages      Message[] @relation("receiver")
  notifications         Notification[]
  pushSubscriptions     PushSubscription[]
  notificationPreference UserNotificationPreference?
  
  // Attendance
  attendanceRecords     Attendance[]
  lmsDiscussions        LmsDiscussion[]
  liveClassAttendance   LiveClassAttendance[]
  liveClassMessages     LiveClassMessage[]
  aiChatSessions        AiChatSession[]
  
  @@index([roleId])
  @@index([schoolId])
  @@index([email])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime @default(now())
  
  @@index([name])
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime @default(now())
}

model RolePermission {
  roleId        String
  permissionId  String
  role          Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  @@id([roleId, permissionId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  ipAddress String?
  userAgent String?
  deviceName String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model AuthToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // email_verify, password_reset, two_factor_login
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([type])
}

model LoginHistory {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress     String?
  userAgent     String?
  deviceLabel   String?
  success       Boolean  @default(true)
  failureReason String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model TwoFactorBackupCode {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ============ SCHOOLS & ORGANIZATION ============
model School {
  id              String   @id @default(uuid())
  name            String
  address         String?
  city            String?
  state           String?
  country         String?
  contactEmail    String?
  contactPhone    String?
  website         String?
  logo            String?
  settings        Json?
  status          String   @default("active") // pending, active, trial, suspended
  bankName        String?
  bankAccountName String?
  bankAccountNumber String?
  primaryColor    String?  @default("#f59e0b")
  secondaryColor  String?  @default("#0b1f4a")
  customDomain    String?
  setupCompleted  Boolean  @default(false)
  approvedAt      DateTime?
  approvedById    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  users           User[]
  classes         Class[]
  subjects        Subject[]
  sessions        Session[]
  students        Student[]
  teachers        Teacher[]
  parents         Parent[]
  fees            Fee[]
  hostels         Hostel[]
  transportRoutes TransportRoute[]
  payments        Payment[]
  subscription    SchoolSubscription?
  registrations   SchoolRegistration[]
  onboarding      SchoolOnboarding?
  subscriptionInvoices SubscriptionInvoice[]
  lmsCourses        LmsCourse[]
  liveClasses       LiveClass[]
  questionBanks     QuestionBank[]
  lessonPlans       LessonPlan[]
  aiChatSessions    AiChatSession[]
  aiGeneratedExams  AiGeneratedExam[]
  aiMarkingSuggestions AiMarkingSuggestion[]
  admissionCycles     AdmissionCycle[]
  admissionApplications AdmissionApplication[]
  jobPostings           JobPosting[]
  employees             Employee[]
  hrManagers            HrManager[]
  payrollSettings       PayrollSetting?
  salaryGrades          SalaryGrade[]
  payrollRuns           PayrollRun[]
  books                 Book[]
  librarySettings       LibrarySetting?
  libraryTransactions   LibraryTransaction[]
  hostelAllocations     HostelAllocation[]
  transportDrivers      TransportDriver[]
  transportVehicles     TransportVehicle[]
  transportAllocations  TransportAllocation[]
  transportLiveLocations TransportLiveLocation[]
  biometricSettings     BiometricSetting?
  biometricDevices      BiometricDevice[]
  biometricEnrollments  BiometricEnrollment[]
  biometricEvents       BiometricEvent[]
  schoolCertificates  SchoolCertificate[]
  digitalIdCards      DigitalIdCard[]
  alumniProfiles      AlumniProfile[]
  alumniEvents        AlumniEvent[]
  alumniDonations     AlumniDonation[]
  alumniMentorships   AlumniMentorship[]
  marketplaceProducts MarketplaceProduct[]
  marketplaceOrders   MarketplaceOrder[]
  publicPosts         PublicPost[]
  publicEvents        PublicEvent[]
  publicGalleryItems  PublicGalleryItem[]
  publicStaffMembers  PublicStaffMember[]
  publicPageContents  PublicPageContent[]
  publicSiteStats     PublicSiteStat[]
  newsletterSubscribers PublicNewsletterSubscriber[]
  notificationSetting NotificationSetting?
  supportTickets      SupportTicket[]
  aiCreditBalance     AiCreditBalance?
  usageDaily          SchoolUsageDaily[]
  referralCodes       ReferralCode[]
  customDomainRecords CustomDomainRecord[]
  billingAddress      BillingAddress?
  subscriptionPayments SubscriptionPayment[]
  subscriptionReceipts SubscriptionReceipt[]
  subscriptionTransactionLogs SubscriptionTransactionLog[]
  schoolAddons        SchoolAddon[]
  featureUsageLogs    FeatureUsageLog[]
  developerApiKeys    DeveloperApiKey[]
  webhookEndpoints    WebhookEndpoint[]
  schoolIntegrations  SchoolIntegration[]
  workflowRules       WorkflowRule[]
  calendarEvents      CalendarEvent[]
  documentFolders     DocumentFolder[]
  documentVault       DocumentVault[]
  customForms         CustomForm[]
  visitorLogs         VisitorLog[]
  maintenanceTickets  MaintenanceTicket[]
  consentForms        ConsentForm[]
  @@index([status])
}

// ============ ACADEMICS ============
model Session {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name        String
  startDate   DateTime
  endDate     DateTime
  active      Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  terms       Term[]
  exams       Exam[]
  
  @@index([schoolId])
  @@index([active])
}

model Term {
  id          String   @id @default(uuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name        String
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())
  
  @@index([sessionId])
}

model Class {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name        String
  level       String
  capacity    Int      @default(50)
  createdAt   DateTime @default(now())
  
  students    Student[]
  subjects    Subject[]
  attendance  Attendance[]
  timetable   Timetable[]
  assignments Assignment[]
  exams       Exam[]
  lmsCourses  LmsCourse[]
  liveClasses LiveClass[]
  lessonPlans LessonPlan[]
  aiGeneratedExams AiGeneratedExam[]
  
  @@index([schoolId])
}

model Subject {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacherId   String?
  teacher     Teacher? @relation(fields: [teacherId], references: [id])
  code        String
  name        String
  description String?
  creditHours Int?
  createdAt   DateTime @default(now())
  
  assignments Assignment[]
  exams       Exam[]
  results     Result[]
  lmsCourses  LmsCourse[]
  liveClasses LiveClass[]
  questionBanks QuestionBank[]
  lessonPlans   LessonPlan[]
  aiGeneratedExams AiGeneratedExam[]
  
  @@index([schoolId])
  @@index([classId])
  @@index([teacherId])
}

model Timetable {
  id          String   @id @default(uuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  day         String
  startTime   String
  endTime     String
  subject     String
  teacher     String?
  room        String?
  createdAt   DateTime @default(now())
  
  @@index([classId])
}

// ============ STUDENTS ============
model Student {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  admissionNo   String   @unique
  classId       String?
  class         Class?   @relation(fields: [classId], references: [id])
  parentId      String?
  parent        Parent?  @relation(fields: [parentId], references: [id])
  dob           DateTime?
  gender        String?
  admissionDate DateTime
  bloodType     String?
  address       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  attendance    Attendance[]
  submissions   Submission[]
  examAnswers   ExamAnswer[]
  results       Result[]
  feePayments   Payment[]
  feeAdjustments FeeAdjustment[]
  transportAllocations TransportAllocation[]
  lmsEnrollments LmsEnrollment[]
  lmsAssignmentSubmissions LmsAssignmentSubmission[]
  lmsCertificates LmsCertificate[]
  liveClassAttendance LiveClassAttendance[]
  examAttempts  ExamAttempt[]
  enrolledFromApplication AdmissionApplication[]
  libraryTransactions LibraryTransaction[]
  hostelAllocations   HostelAllocation[]
  biometricEnrollments BiometricEnrollment[]
  biometricEvents     BiometricEvent[]
  schoolCertificates  SchoolCertificate[]
  digitalIdCards      DigitalIdCard[]

  @@index([userId])
  @@index([schoolId])
  @@index([classId])
  @@index([admissionNo])
}

// ============ TEACHERS ============
model Teacher {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staffNo       String   @unique
  department    String?
  hireDate      DateTime
  qualification String?
  specialization String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  subjects      Subject[]
  assignments   Assignment[]
  exams         Exam[]
  lmsCourses    LmsCourse[]
  liveClasses   LiveClass[]
  lessonPlans   LessonPlan[]
  aiGeneratedExams AiGeneratedExam[]
  aiMarkingSuggestions AiMarkingSuggestion[]
  employee             Employee?
  
  @@index([userId])
  @@index([schoolId])
  @@index([staffNo])
}

// ============ PARENTS ============
model Parent {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  occupation    String?
  createdAt     DateTime @default(now())
  
  children      Student[]
  
  @@index([userId])
  @@index([schoolId])
}

// ============ ACCOUNTANT ============
model Accountant {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  staffNo       String   @unique
  createdAt     DateTime @default(now())
  
  @@index([userId])
}

// ============ LIBRARIAN ============
model Librarian {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  staffNo       String   @unique
  createdAt     DateTime @default(now())
  
  @@index([userId])
}

// ============ HOSTEL MANAGER ============
model HostelManager {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  staffNo       String   @unique
  createdAt     DateTime @default(now())
  
  @@index([userId])
}

// ============ TRANSPORT MANAGER ============
model TransportManager {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  staffNo       String   @unique
  createdAt     DateTime @default(now())
  
  @@index([userId])
}

// ============ BIOMETRIC MANAGER ============
model BiometricManager {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  staffNo       String   @unique
  createdAt     DateTime @default(now())

  @@index([userId])
}

// ============ BIOMETRICS ============
model BiometricSetting {
  id                   String   @id @default(uuid())
  schoolId             String   @unique
  school               School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fingerprintEnabled   Boolean  @default(true)
  facialEnabled        Boolean  @default(true)
  autoMarkAttendance   Boolean  @default(true)
  accessControlEnabled Boolean  @default(true)
  minMatchScore        Float    @default(0.85)
  updatedAt            DateTime @updatedAt
}

model BiometricDevice {
  id         String   @id @default(uuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name       String
  location   String
  deviceType String   // gate, classroom, office
  methods    String   @default("fingerprint,facial")
  direction  String?  // in, out, both
  apiKey     String   @unique @default(uuid())
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  events BiometricEvent[]

  @@index([schoolId])
}

model BiometricEnrollment {
  id           String    @id @default(uuid())
  schoolId     String
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  personType   String    // student, employee
  studentId    String?
  student      Student?  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  employeeId   String?
  employee     Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  method       String    // fingerprint, facial
  templateHash String
  label        String?
  status       String    @default("active")
  enrolledAt   DateTime  @default(now())
  enrolledById String?

  @@unique([schoolId, studentId, method])
  @@unique([schoolId, employeeId, method])
  @@index([schoolId])
  @@index([templateHash])
}

model BiometricEvent {
  id           String           @id @default(uuid())
  schoolId     String
  school       School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  deviceId     String?
  device       BiometricDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  eventType    String           // attendance, access
  method       String
  personType   String
  studentId    String?
  student      Student?         @relation(fields: [studentId], references: [id], onDelete: SetNull)
  employeeId   String?
  employee     Employee?        @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  direction    String?
  matchScore   Float?
  status       String           // granted, denied, failed
  attendanceId String?
  attendance   Attendance?      @relation(fields: [attendanceId], references: [id], onDelete: SetNull)
  notes        String?
  createdAt    DateTime         @default(now())

  @@index([schoolId])
  @@index([deviceId])
  @@index([eventType])
  @@index([createdAt])
}

// ============ ATTENDANCE ============
model Attendance {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  date        DateTime
  status      String   // Present, Absent, Late, Excused
  markedById  String
  markedBy    User     @relation(fields: [markedById], references: [id])
  remark      String?
  source      String?  @default("manual") // manual, biometric
  createdAt   DateTime @default(now())
  
  biometricEvents BiometricEvent[]

  @@unique([studentId, classId, date])
  @@index([studentId])
  @@index([classId])
  @@index([date])
}

// ============ ASSIGNMENTS ============
model Assignment {
  id          String   @id @default(uuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  title       String
  description String?
  fileUrl     String?
  dueDate     DateTime
  totalMarks  Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  submissions Submission[]
  
  @@index([classId])
  @@index([teacherId])
}

model Submission {
  id          String   @id @default(uuid())
  assignmentId String
  assignment  Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fileUrl     String
  grade       Int?
  feedback    String?
  submittedAt DateTime
  createdAt   DateTime @default(now())
  
  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
}

// ============ EXAMS & CBT ============
model Exam {
  id          String   @id @default(uuid())
  schoolId    String?
  sessionId   String?
  session     Session? @relation(fields: [sessionId], references: [id])
  classId     String?
  class       Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  name        String
  type        String   // "CBT", "Essay", "Practical"
  startDate   DateTime
  endDate     DateTime
  duration    Int      // in minutes
  totalMarks  Int      @default(100)
  instructions String?
  randomizeQuestions Boolean @default(false)
  randomizeOptions   Boolean @default(false)
  showAnswersAfter Boolean @default(true)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  questions   Question[]
  answers     ExamAnswer[]
  results     Result[]
  attempts    ExamAttempt[]
  
  @@index([subjectId])
  @@index([teacherId])
}

model Question {
  id          String   @id @default(uuid())
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  type        String   // "MCQ", "Essay", "TrueFalse", "ShortAnswer"
  content     String
  mark        Int      @default(1)
  
  // MCQ options
  options     QuestionOption[]
  correctAnswer String?
  
  answers     ExamAnswer[]
  
  @@index([examId])
}

model QuestionOption {
  id          String   @id @default(uuid())
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label       String   // A, B, C, D, etc.
  text        String
  isCorrect   Boolean  @default(false)
  
  @@index([questionId])
}

model ExamAnswer {
  id          String   @id @default(uuid())
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerText  String?
  selectedOption String?
  marksObtained Int?
  autoGraded  Boolean  @default(false)
  submittedAt DateTime
  createdAt   DateTime @default(now())
  
  @@unique([examId, studentId, questionId])
  @@index([examId])
  @@index([studentId])
}

model ExamAttempt {
  id             String    @id @default(uuid())
  examId         String
  exam           Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId      String
  student        Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  startedAt      DateTime  @default(now())
  expiresAt      DateTime
  submittedAt    DateTime?
  status         String    @default("in_progress")
  tabSwitchCount Int       @default(0)
  questionOrder  Json?
  optionOrder    Json?

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
}

model QuestionBank {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subjectId   String?
  subject     Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items QuestionBankItem[]

  @@index([schoolId])
  @@index([subjectId])
}

model QuestionBankItem {
  id            String   @id @default(uuid())
  bankId        String
  bank          QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)
  type          String
  content       String
  mark          Int      @default(1)
  correctAnswer String?
  createdAt     DateTime @default(now())

  options QuestionBankOption[]

  @@index([bankId])
}

model QuestionBankOption {
  id        String           @id @default(uuid())
  itemId    String
  item      QuestionBankItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  label     String
  text      String
  isCorrect Boolean          @default(false)

  @@index([itemId])
}

// ============ RESULTS ============
model Result {
  id          String   @id @default(uuid())
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  totalScore  Float
  grade       String?
  gpa         Float?
  percentile  Float?
  rank        Int?
  feedback    String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  
  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
}

// ============ FINANCE ============
model Fee {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId     String?
  name        String
  amount      Float
  dueDate     DateTime
  description String?
  isActive    Boolean  @default(true)
  allowPartial Boolean @default(true)
  createdAt   DateTime @default(now())

  payments      Payment[]
  installments  FeeInstallment[]
  adjustments   FeeAdjustment[]

  @@index([schoolId])
}

model FeeInstallment {
  id        String   @id @default(uuid())
  feeId     String
  fee       Fee      @relation(fields: [feeId], references: [id], onDelete: Cascade)
  label     String
  amount    Float
  dueDate   DateTime
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  payments  Payment[]

  @@index([feeId])
}

model FeeAdjustment {
  id        String   @id @default(uuid())
  schoolId  String
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeId     String?
  fee       Fee?     @relation(fields: [feeId], references: [id], onDelete: SetNull)
  type      String   // scholarship, waiver, sibling_discount, penalty
  value     Float
  isPercent Boolean  @default(false)
  reason    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([schoolId])
  @@index([studentId])
}

model FinanceLedger {
  id          String   @id @default(uuid())
  schoolId    String
  entryType   String   // income, expense
  category    String
  amount      Float
  paymentId   String?
  payment     Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  description String?
  reference   String?
  entryDate   DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([schoolId])
  @@index([entryDate])
}

model Payment {
  id                 String   @id @default(uuid())
  schoolId           String?
  school             School?  @relation(fields: [schoolId], references: [id])
  feeId              String?
  fee                Fee?     @relation(fields: [feeId], references: [id])
  installmentId      String?
  installment        FeeInstallment? @relation(fields: [installmentId], references: [id], onDelete: SetNull)
  studentId          String
  student            Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount             Float
  paidAmount         Float    @default(0)
  discountApplied    Float    @default(0)
  penaltyApplied     Float    @default(0)
  gateway            String   // paystack, flutterwave, stripe, manual
  status             String   @default("pending") // pending, completed, failed, partial
  verificationStatus String   @default("none") // none, pending_verification, under_review, approved, rejected
  paymentReference   String?  @unique
  receiptNumber      String?  @unique
  transactionId      String?
  receiptUrl         String?
  receiptMimeType    String?
  reviewedById       String?
  reviewedBy         User?    @relation("PaymentReviewer", fields: [reviewedById], references: [id])
  reviewedAt         DateTime?
  reviewNote         String?
  paidAt             DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  verificationLogs   PaymentVerificationLog[]
  ledgerEntries      FinanceLedger[]

  @@index([studentId])
  @@index([schoolId])
  @@index([status])
  @@index([verificationStatus])
  @@index([paymentReference])
}

model PaymentVerificationLog {
  id            String   @id @default(uuid())
  paymentId     String
  payment       Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  action        String   // submitted, under_review, approved, rejected, info_requested
  note          String?
  performedById String
  performedBy   User     @relation(fields: [performedById], references: [id])
  createdAt     DateTime @default(now())

  @@index([paymentId])
  @@index([performedById])
}

// ============ LIBRARY ============
model LibrarySetting {
  id                 String   @id @default(uuid())
  schoolId           String   @unique
  school             School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  loanDays           Int      @default(14)
  finePerDay         Float    @default(50)
  maxBooksPerStudent Int      @default(3)
  currency           String   @default("NGN")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Book {
  id              String   @id @default(uuid())
  schoolId        String?
  school          School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title           String
  author          String
  isbn            String?
  publisher       String?
  year            Int?
  copies          Int      @default(1)
  availableCopies Int      @default(1)
  category        String?
  description     String?
  thumbnail       String?
  createdAt       DateTime @default(now())

  transactions LibraryTransaction[]

  @@index([title])
  @@index([isbn])
  @@index([schoolId])
  @@index([category])
}

model LibraryTransaction {
  id         String    @id @default(uuid())
  schoolId   String
  school     School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  bookId     String
  book       Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  issueDate  DateTime
  dueDate    DateTime
  returnDate DateTime?
  fineAmount Float     @default(0)
  returned   Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@index([bookId])
  @@index([studentId])
  @@index([schoolId])
  @@index([returned])
}

// ============ HOSTEL ============
model Hostel {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name        String
  capacity    Int
  gender      String   @default("mixed")
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  rooms Room[]

  @@index([schoolId])
}

model Room {
  id               String   @id @default(uuid())
  hostelId         String
  hostel           Hostel   @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  roomNumber       String
  floor            String?
  capacity         Int
  currentOccupancy Int      @default(0)
  costPerTerm      Float?
  amenities        Json?
  createdAt        DateTime @default(now())

  allocations HostelAllocation[]

  @@unique([hostelId, roomNumber])
  @@index([hostelId])
}

model HostelAllocation {
  id             String    @id @default(uuid())
  schoolId       String?
  school         School?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  roomId         String
  room           Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  studentId      String?
  student        Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  allocationDate DateTime
  releaseDate    DateTime?
  status         String    @default("active")
  createdAt      DateTime  @default(now())

  @@index([roomId])
  @@index([studentId])
  @@index([schoolId])
  @@index([status])
}

// ============ TRANSPORT ============
model TransportDriver {
  id        String   @id @default(uuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  licenseNo String?
  status    String   @default("active")
  createdAt DateTime @default(now())

  vehicles TransportVehicle[]

  @@index([schoolId])
}

model TransportVehicle {
  id             String   @id @default(uuid())
  schoolId       String?
  school         School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  registrationNo String   @unique
  model          String
  capacity       Int
  driverRecordId String?
  driverRecord   TransportDriver? @relation(fields: [driverRecordId], references: [id], onDelete: SetNull)
  driverName     String?
  driverPhone    String?
  status         String   @default("Active")
  createdAt      DateTime @default(now())

  allocations  TransportAllocation[]
  liveLocation TransportLiveLocation?

  @@index([schoolId])
  @@index([registrationNo])
}

model TransportRoute {
  id               String   @id @default(uuid())
  schoolId         String
  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name             String
  startPoint       String
  endPoint         String
  fare             Float
  estimatedMinutes Int?
  stopsCount       Int      @default(0)
  distanceKm       Float?
  createdAt        DateTime @default(now())

  allocations TransportAllocation[]

  @@index([schoolId])
}

model TransportAllocation {
  id        String    @id @default(uuid())
  schoolId  String?
  school    School?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  vehicleId String
  vehicle   TransportVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  routeId   String
  route     TransportRoute   @relation(fields: [routeId], references: [id], onDelete: Cascade)
  studentId String?
  student   Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  status    String    @default("active")
  createdAt DateTime  @default(now())
  releaseDate DateTime?

  @@index([vehicleId])
  @@index([routeId])
  @@index([studentId])
  @@index([schoolId])
  @@index([status])
}

model TransportLiveLocation {
  id         String           @id @default(uuid())
  schoolId   String
  school     School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  vehicleId  String           @unique
  vehicle    TransportVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  routeId    String?
  latitude   Float
  longitude  Float
  etaMinutes Int?
  status     String           @default("idle")
  updatedAt  DateTime         @updatedAt

  @@index([schoolId])
}

// ============ MESSAGING ============
model Message {
  id            String   @id @default(uuid())
  senderId      String
  sender        User     @relation("sender", fields: [senderId], references: [id])
  receiverId    String
  receiver      User     @relation("receiver", fields: [receiverId], references: [id])
  subject       String?
  body          String
  attachments   String[] @default([])
  read          Boolean  @default(false)
  readAt        DateTime?
  createdAt     DateTime @default(now())
  
  @@index([senderId])
  @@index([receiverId])
  @@index([read])
}

// ============ NOTIFICATIONS ============
model Notification {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String   // "assignment", "exam", "fee", "announcement"
  title         String
  body          String
  payload       Json?
  read          Boolean  @default(false)
  readAt        DateTime?
  sentAt        DateTime @default(now())
  createdAt     DateTime @default(now())
  
  @@index([userId])
  @@index([read])
}

// ============ ANNOUNCEMENTS ============
model Announcement {
  id            String   @id @default(uuid())
  schoolId      String?
  title         String
  content       String
  image         String?
  priority      String   @default("normal") // "low", "normal", "high"
  published     Boolean  @default(false)
  publishedAt   DateTime?
  expireAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([schoolId])
}

// ============ LMS ============
model LmsCourse {
  id          String    @id @default(uuid())
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title       String
  description String?
  thumbnail   String?
  subjectId   String?
  subject     Subject?  @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  classId     String?
  class       Class?    @relation(fields: [classId], references: [id], onDelete: SetNull)
  teacherId   String?
  teacher     Teacher?  @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  modules      LmsModule[]
  enrollments  LmsEnrollment[]
  assignments  LmsAssignment[]
  discussions  LmsDiscussion[]
  certificates LmsCertificate[]

  @@index([schoolId])
  @@index([classId])
  @@index([published])
}

model LmsModule {
  id          String    @id @default(uuid())
  courseId    String
  course      LmsCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lessons LmsLesson[]

  @@index([courseId])
}

model LmsLesson {
  id          String    @id @default(uuid())
  moduleId    String
  module      LmsModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  content     String?
  type        String    @default("text") // video, pdf, text
  resourceUrl String?
  durationMin Int?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  progress LmsLessonProgress[]

  @@index([moduleId])
}

model LmsEnrollment {
  id              String    @id @default(uuid())
  courseId        String
  course          LmsCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  progressPercent Int       @default(0)
  completedAt     DateTime?
  enrolledAt      DateTime  @default(now())

  lessonProgress LmsLessonProgress[]

  @@unique([courseId, studentId])
  @@index([studentId])
}

model LmsLessonProgress {
  id           String        @id @default(uuid())
  enrollmentId String
  enrollment   LmsEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       LmsLesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed    Boolean       @default(false)
  completedAt  DateTime?

  @@unique([enrollmentId, lessonId])
  @@index([lessonId])
}

model LmsAssignment {
  id          String    @id @default(uuid())
  courseId    String
  course      LmsCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonId    String?
  title       String
  description String?
  resourceUrl String?
  dueDate     DateTime?
  totalMarks  Int       @default(100)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  submissions LmsAssignmentSubmission[]

  @@index([courseId])
}

model LmsAssignmentSubmission {
  id           String        @id @default(uuid())
  assignmentId String
  assignment   LmsAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fileUrl      String?
  textAnswer   String?
  grade        Int?
  feedback     String?
  submittedAt  DateTime      @default(now())

  @@unique([assignmentId, studentId])
  @@index([studentId])
}

model LmsDiscussion {
  id        String         @id @default(uuid())
  courseId  String
  course    LmsCourse      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonId  String?
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  parentId  String?
  parent    LmsDiscussion? @relation("LmsDiscussionThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   LmsDiscussion[] @relation("LmsDiscussionThread")
  createdAt DateTime       @default(now())

  @@index([courseId])
  @@index([userId])
}

model LmsCertificate {
  id                String    @id @default(uuid())
  courseId          String
  course            LmsCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studentId         String
  student           Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  certificateNumber String    @unique
  verifyCode        String    @unique
  issuedAt          DateTime  @default(now())

  @@unique([courseId, studentId])
  @@index([verifyCode])
}

// ============ SCHOOL CERTIFICATES ============
model SchoolCertificate {
  id                String    @id @default(uuid())
  schoolId          String
  school            School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  certificateType     String    // graduation, attendance, excellence
  title             String
  studentId         String?
  student           Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  employeeId        String?
  employee          Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  recipientName     String
  description       String?
  sessionLabel      String?
  className         String?
  metadata          Json?
  certificateNumber String    @unique
  verifyCode        String    @unique
  issuedById        String?
  issuedAt          DateTime  @default(now())
  revokedAt         DateTime?
  status            String    @default("active")

  @@index([schoolId])
  @@index([studentId])
  @@index([certificateType])
  @@index([verifyCode])
  @@index([status])
}

// ============ DIGITAL ID CARDS ============
model DigitalIdCard {
  id                  String    @id @default(uuid())
  schoolId            String
  school              School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  cardType            String    // student, staff
  studentId           String?
  student             Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  employeeId          String?
  employee            Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  cardNumber          String    @unique
  verifyCode          String    @unique
  holderName          String
  photoUrl            String?
  roleLabel           String?
  departmentOrClass   String?
  idNumber            String?
  bloodType           String?
  expiresAt           DateTime
  issuedAt            DateTime  @default(now())
  issuedById          String?
  status              String    @default("active")

  @@index([schoolId])
  @@index([studentId])
  @@index([employeeId])
  @@index([verifyCode])
  @@index([status])
  @@index([expiresAt])
}

// ============ ALUMNI ============
model AlumniProfile {
  id              String   @id @default(uuid())
  schoolId        String
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  studentId       String?
  firstName       String
  lastName        String
  email           String
  phone           String?
  graduationYear  Int?
  className       String?
  degree          String?
  currentRole     String?
  company         String?
  city            String?
  country         String?
  bio             String?
  linkedinUrl     String?
  photoUrl        String?
  isPublic        Boolean  @default(true)
  openToMentor    Boolean  @default(false)
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rsvps           AlumniEventRsvp[]
  donations       AlumniDonation[]
  mentorSessions  AlumniMentorship[] @relation("MentorAlumni")
  menteeSessions  AlumniMentorship[] @relation("MenteeAlumni")

  @@unique([schoolId, email])
  @@index([schoolId])
  @@index([graduationYear])
}

model AlumniEvent {
  id           String   @id @default(uuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  venue        String?
  eventDate    DateTime
  endDate      DateTime?
  capacity     Int?
  isPublic     Boolean  @default(true)
  status       String   @default("published")
  createdAt    DateTime @default(now())

  rsvps        AlumniEventRsvp[]

  @@index([schoolId])
  @@index([eventDate])
}

model AlumniEventRsvp {
  id         String        @id @default(uuid())
  eventId    String
  event      AlumniEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  alumniId   String
  alumni     AlumniProfile @relation(fields: [alumniId], references: [id], onDelete: Cascade)
  status     String        @default("going")
  guests     Int           @default(1)
  createdAt  DateTime      @default(now())

  @@unique([eventId, alumniId])
  @@index([eventId])
}

model AlumniDonation {
  id          String         @id @default(uuid())
  schoolId    String
  school      School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  alumniId    String?
  alumni      AlumniProfile? @relation(fields: [alumniId], references: [id], onDelete: SetNull)
  donorName   String
  donorEmail  String
  amount      Float
  currency    String         @default("NGN")
  gateway     String         @default("paystack")
  reference   String         @unique
  status      String         @default("pending")
  message     String?
  receiptUrl  String?
  paidAt      DateTime?
  createdAt   DateTime       @default(now())

  @@index([schoolId])
  @@index([status])
}

model AlumniMentorship {
  id               String         @id @default(uuid())
  schoolId         String
  school           School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  mentorId         String
  mentor           AlumniProfile  @relation("MentorAlumni", fields: [mentorId], references: [id], onDelete: Cascade)
  menteeAlumniId   String?
  menteeAlumni     AlumniProfile? @relation("MenteeAlumni", fields: [menteeAlumniId], references: [id], onDelete: SetNull)
  menteeStudentId  String?
  menteeName       String
  menteeEmail      String
  focusArea        String?
  status           String         @default("pending")
  notes            String?
  matchedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([schoolId])
  @@index([mentorId])
  @@index([status])
}

// ============ MARKETPLACE ============
model MarketplaceProduct {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name        String
  description String?
  category    String   @default("supplies") // uniform, book, supplies
  sku         String?
  price       Float
  currency    String   @default("NGN")
  imageUrl    String?
  sizes       String[] @default([])
  stockQty    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cartItems   MarketplaceCartItem[]
  orderItems  MarketplaceOrderItem[]

  @@index([schoolId])
  @@index([category])
  @@index([isActive])
}

model MarketplaceCartItem {
  id        String             @id @default(uuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   MarketplaceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int                @default(1)
  size      String             @default("")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([userId, productId, size])
  @@index([userId])
}

model MarketplaceOrder {
  id               String   @id @default(uuid())
  schoolId         String
  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderNumber      String   @unique
  customerName     String
  customerEmail    String
  totalAmount      Float
  currency         String   @default("NGN")
  gateway          String?
  reference        String?  @unique
  paymentReceiptUrl String?
  status           String   @default("pending")
  fulfillmentNotes String?
  paidAt           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items MarketplaceOrderItem[]

  @@index([schoolId])
  @@index([userId])
  @@index([status])
}

model MarketplaceOrderItem {
  id          String              @id @default(uuid())
  orderId     String
  order       MarketplaceOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     MarketplaceProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String
  size        String?
  quantity    Int
  unitPrice   Float
  subtotal    Float

  @@index([orderId])
}

// ============ PUBLIC WEBSITE CMS ============
model PublicPost {
  id          String    @id @default(uuid())
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  postType    String    @default("news")
  slug        String
  title       String
  excerpt     String?
  body        String    @db.Text
  author      String?
  imageUrl    String?
  badge       String?
  icon        String?
  published   Boolean   @default(true)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([schoolId, slug])
  @@index([schoolId, postType, published])
}

model PublicEvent {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title       String
  description String?
  venue       String?
  category    String?
  eventDate   DateTime
  isFeatured  Boolean  @default(false)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([schoolId, eventDate])
  @@index([published])
}

model PublicGalleryItem {
  id         String   @id @default(uuid())
  schoolId   String
