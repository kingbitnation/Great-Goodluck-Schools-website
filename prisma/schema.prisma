  payeTaxRate         Float    @default(7.5)
  pensionEmployeeRate Float    @default(8)
  pensionEmployerRate Float    @default(10)
  nhfRate             Float    @default(2.5)
  taxFreeAllowance    Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model SalaryGrade {
  id         String   @id @default(uuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name       String
  baseSalary Float
  allowances Json?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  profiles EmployeePayrollProfile[]

  @@index([schoolId])
}

model EmployeePayrollProfile {
  id               String       @id @default(uuid())
  employeeId       String       @unique
  employee         Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  gradeId          String?
  grade            SalaryGrade? @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  baseSalary       Float
  allowances       Json?
  bankName         String?
  bankAccount      String?
  customDeductions Json?
  effectiveFrom    DateTime     @default(now())
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model PayrollRun {
  id              String    @id @default(uuid())
  schoolId        String
  school          School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  periodLabel     String
  month           Int
  year            Int
  status          String    @default("draft")
  totalGross      Float     @default(0)
  totalNet        Float     @default(0)
  totalDeductions Float     @default(0)
  processedById   String?
  approvedAt      DateTime?
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  payslips Payslip[]

  @@unique([schoolId, month, year])
  @@index([schoolId])
  @@index([status])
}

model Payslip {
  id                    String     @id @default(uuid())
  payrollRunId          String
  payrollRun            PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId            String
  employee              Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeNo            String
  employeeName          String
  department            String?
  jobTitle              String?
  grossPay              Float
  totalDeductions       Float
  netPay                Float
  earnings              Json
  deductions            Json
  employerContributions Json?
  status                String     @default("draft")
  paidAt                DateTime?
  createdAt             DateTime   @default(now())

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
  @@index([status])
}

// ============ PLATFORM SAAS (Super Admin) ============
model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  label       String
  description String?
  enabled     Boolean  @default(true)
  planSlugs   String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BillingCoupon {
  id            String   @id @default(uuid())
  code          String   @unique
  description   String?
  discountType  String   @default("percent")
  discountValue Float
  maxUses       Int?
  usedCount     Int      @default(0)
  validFrom     DateTime @default(now())
  validUntil    DateTime?
  planSlugs     String[] @default([])
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model SupportTicket {
  id             String   @id @default(uuid())
  schoolId       String
  school         School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  assignedToId   String?
  assignedTo     User?    @relation("TicketAssignee", fields: [assignedToId], references: [id])
  subject        String
  category       String   @default("general")
  priority       String   @default("normal")
  status         String   @default("open")
  rating         Int?
  internalNotes  String?
  attachmentUrls String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  closedAt       DateTime?
  messages       SupportTicketMessage[]

  @@index([schoolId])
  @@index([status])
  @@index([createdById])
}

model SupportTicketMessage {
  id         String   @id @default(uuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body       String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([ticketId])
}

model AiCreditBalance {
  schoolId      String   @id
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  monthlyGrant  Int      @default(0)
  balance       Int      @default(0)
  usedThisMonth Int      @default(0)
  periodStart   DateTime?
  updatedAt     DateTime @updatedAt
  transactions  AiCreditTransaction[]
}

model AiCreditTransaction {
  id        String   @id @default(uuid())
  schoolId  String
  balance   AiCreditBalance @relation(fields: [schoolId], references: [schoolId], onDelete: Cascade)
  amount    Int
  type      String
  note      String?
  createdAt DateTime @default(now())

  @@index([schoolId])
  @@index([createdAt])
}

model SchoolUsageDaily {
  id           String   @id @default(uuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  date         DateTime @db.Date
  storageBytes BigInt   @default(0)
  apiRequests  Int      @default(0)
  aiRequests   Int      @default(0)
  smsSent      Int      @default(0)
  emailsSent   Int      @default(0)
  activeUsers  Int      @default(0)
  logins       Int      @default(0)

  @@unique([schoolId, date])
  @@index([date])
}

model ReferralCode {
  id               String   @id @default(uuid())
  schoolId         String
  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  code             String   @unique
  rewardDays       Int      @default(14)
  rewardAiCredits  Int      @default(50)
  rewardSmsCredits Int      @default(100)
  conversions      ReferralConversion[]
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
}

model ReferralConversion {
  id               String   @id @default(uuid())
  referralCodeId   String
  referralCode     ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)
  referredSchoolId String   @unique
  status           String   @default("pending")
  rewardedAt       DateTime?
  createdAt        DateTime @default(now())
}

model CustomDomainRecord {
  id                String   @id @default(uuid())
  schoolId          String
  school            School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  domain            String   @unique
  verificationToken String
  status            String   @default("pending")
  dnsVerifiedAt     DateTime?
  sslStatus         String   @default("pending")
  sslExpiresAt      DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([schoolId])
}

model PlatformAnnouncement {
  id          String   @id @default(uuid())
  title       String
  body        String
  targetRoles String[] @default([])
  planSlugs   String[] @default([])
  publishAt   DateTime @default(now())
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model PlatformHealthIncident {
  id          String   @id @default(uuid())
  title       String
  description String?
  severity    String   @default("minor")
  status      String   @default("investigating")
  startedAt   DateTime @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
}

// ============ ENTERPRISE: DEVELOPER & INTEGRATIONS ============
model DeveloperApiKey {
  id          String    @id @default(uuid())
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name        String
  keyPrefix   String
  keyHash     String    @unique
  scopes      String[]  @default([])
  rateLimit   Int       @default(1000)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdById String?
  createdAt   DateTime  @default(now())

  @@index([schoolId])
  @@index([keyPrefix])
}

model WebhookEndpoint {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  url         String
  secret      String
  events      String[] @default([])
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deliveries  WebhookDelivery[]

  @@index([schoolId])
}

model WebhookDelivery {
  id           String   @id @default(uuid())
  endpointId   String
  endpoint     WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  event        String
  payload      Json
  status       String   @default("pending")
  responseCode Int?
  responseBody String?
  attempts     Int      @default(0)
  nextRetryAt  DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime @default(now())

  @@index([endpointId])
  @@index([status])
  @@index([createdAt])
}

model IntegrationProvider {
  id           String   @id @default(uuid())
  slug         String   @unique
  name         String
  category     String   @default("general")
  description  String?
  iconUrl      String?
  configSchema Json?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
}

model SchoolIntegration {
  id           String    @id @default(uuid())
  schoolId     String
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  providerSlug String
  status       String    @default("disconnected")
  config       Json?
  lastSyncAt   DateTime?
  lastError    String?
  connectedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([schoolId, providerSlug])
  @@index([schoolId])
  @@index([providerSlug])
}

model WorkflowRule {
  id          String    @id @default(uuid())
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name        String
  description String?
  trigger     String
  conditions  Json?
  actions     Json
  isActive    Boolean   @default(true)
  runCount    Int       @default(0)
  lastRunAt   DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  runs        WorkflowRun[]

  @@index([schoolId])
  @@index([trigger])
  @@index([isActive])
}

model WorkflowRun {
  id        String   @id @default(uuid())
  ruleId    String
  rule      WorkflowRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  status    String   @default("completed")
  trigger   String?
  context   Json?
  log       Json?
  createdAt DateTime @default(now())

  @@index([ruleId])
  @@index([createdAt])
}

// ============ CALENDAR HUB ============
model CalendarEvent {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean  @default(false)
  category    String   @default("custom")
  color       String?  @default("#f59e0b")
  location    String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
  @@index([startAt])
  @@index([category])
}

// ============ DOCUMENT VAULT ============
model DocumentFolder {
  id        String   @id @default(uuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    DocumentFolder? @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  DocumentFolder[] @relation("FolderTree")
  name      String
  createdAt DateTime @default(now())

  documents DocumentVault[]

  @@index([schoolId])
  @@index([parentId])
}

model DocumentVault {
  id               String    @id @default(uuid())
  schoolId         String
  school           School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  folderId         String?
  folder           DocumentFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  title            String
  category         String    @default("general")
  description      String?
  visibility       String    @default("staff")
  allowedRoles     String[]  @default([])
  studentId        String?
  employeeId       String?
  expiresAt        DateTime?
  archivedAt       DateTime?
  createdById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  versions         DocumentVersion[]

  @@index([schoolId])
  @@index([folderId])
  @@index([category])
  @@index([expiresAt])
  @@index([studentId])
}

model DocumentVersion {
  id           String   @id @default(uuid())
  documentId   String
  document     DocumentVault @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionNumber Int
  fileUrl      String
  mimeType     String?
  fileSize     Int?
  changeNote   String?
  uploadedById String?
  createdAt    DateTime @default(now())

  @@unique([documentId, versionNumber])
  @@index([documentId])
}

// ============ CUSTOM FORMS ============
model CustomForm {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title       String
  slug        String
  description String?
  category    String   @default("general")
  fields      Json
  isPublished Boolean  @default(false)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  submissions FormSubmission[]

  @@unique([schoolId, slug])
  @@index([schoolId])
}

model FormSubmission {
  id           String   @id @default(uuid())
  formId       String
  form         CustomForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  data         Json
  submitterEmail String?
  submitterName  String?
  status       String   @default("submitted")
  createdAt    DateTime @default(now())

  @@index([formId])
}

// ============ VISITOR MANAGEMENT ============
model VisitorLog {
  id           String    @id @default(uuid())
  schoolId     String
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fullName     String
  phone        String?
  purpose      String
  hostName     String?
  passCode     String    @unique
  photoUrl     String?
  status       String    @default("checked_in")
  checkInAt    DateTime  @default(now())
  checkOutAt   DateTime?
  registeredById String?
  createdAt    DateTime  @default(now())

  @@index([schoolId])
  @@index([status])
}

// ============ MAINTENANCE ============
model MaintenanceTicket {
  id           String    @id @default(uuid())
  schoolId     String
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title        String
  description  String
  category     String    @default("general")
  priority     String    @default("medium")
  status       String    @default("open")
  location     String?
  reportedById String?
  assignedToId String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([schoolId])
  @@index([status])
  @@index([priority])
}

// ============ PARENT CONSENT ============
model ConsentForm {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title       String
  description String?
  body        String
  classId     String?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  responses   ConsentResponse[]

  @@index([schoolId])
}

model ConsentResponse {
  id            String   @id @default(uuid())
  formId        String
  form          ConsentForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  parentId      String?
  studentId     String?
  status        String   @default("pending")
  signatureName String?
  signedAt      DateTime?
  note          String?
  createdAt     DateTime @default(now())

  @@index([formId])
  @@index([parentId])
  @@index([studentId])
}
