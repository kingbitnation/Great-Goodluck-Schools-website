# SchoolPilot — environment template (copy to .env and fill in)

NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://user:pass@localhost:5432/schoolpilot

JWT_SECRET=change-me-in-production
REFRESH_SECRET=change-me-in-production
APP_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=SchoolPilot
SMTP_FROM_NAME=SchoolPilot
SMTP_FROM=SchoolPilot <noreply@yourdomain.com>

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SMS_PROVIDER=termii
TERMII_API_KEY=
TERMII_SENDER_ID=SchoolPilot

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o
