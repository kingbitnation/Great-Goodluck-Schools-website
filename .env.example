# PostgreSQL connection (use @db:5432 when running backend inside docker-compose)

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/schooldb"



# Use long random strings in production (e.g. openssl rand -base64 48)
# Server refuses dev defaults when NODE_ENV=production

JWT_SECRET=dev_secret_change_me

REFRESH_SECRET=dev_refresh_change_me



NODE_ENV=development
# Set TRUST_PROXY=true behind nginx/Caddy/load balancer in production
TRUST_PROXY=false

PORT=4000

NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# Docker frontend build/runtime — proxy to backend container (do not use localhost inside Docker)
API_INTERNAL_URL=http://backend:4000

APP_URL=http://localhost:3000

API_PUBLIC_URL=http://localhost:4000



# Email (Gmail: use App Password, SMTP_SECURE=false on port 587)

SMTP_HOST=smtp.gmail.com

SMTP_PORT=587

SMTP_SECURE=false

SMTP_USER=your@gmail.com

SMTP_PASS=your_app_password

SMTP_FROM="Great Goodluck Schools <your@gmail.com>"



# Cloudinary — https://console.cloudinary.com/app/settings/api-keys (optional; local uploads used if unset)

CLOUDINARY_CLOUD_NAME=

CLOUDINARY_API_KEY=

CLOUDINARY_API_SECRET=

UPLOAD_MAX_BYTES=10485760



# Payment gateways (optional — or per-school in settings.gateways)

PAYSTACK_SECRET_KEY=

PAYSTACK_PUBLIC_KEY=

FLUTTERWAVE_SECRET_KEY=

FLUTTERWAVE_PUBLIC_KEY=

FLUTTERWAVE_SECRET_HASH=

STRIPE_SECRET_KEY=

STRIPE_PUBLISHABLE_KEY=

STRIPE_WEBHOOK_SECRET=

# OAuth integrations (Google Workspace, Zoom)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Encrypts school integration secrets at rest (defaults to JWT_SECRET if unset)
INTEGRATION_ENCRYPTION_KEY=

# Optional — distributed rate limiting (npm install ioredis)
REDIS_URL=

# Platform bank account (SaaS subscription transfers)
PLATFORM_BANK_NAME=
PLATFORM_BANK_ACCOUNT_NAME=
PLATFORM_BANK_ACCOUNT_NUMBER=


# AI Suite (OpenRouter preferred — demo mode works without a key)

OPENROUTER_API_KEY=

OPENROUTER_MODEL=openai/gpt-4o

OPENAI_API_KEY=

AI_MODEL=openai/gpt-4o

AI_MAX_TOKENS=2048



# SMS (optional — or per-school in notification settings)

SMS_PROVIDER=termii

TERMII_API_KEY=

TERMII_SENDER_ID=

TWILIO_ACCOUNT_SID=

TWILIO_AUTH_TOKEN=

TWILIO_FROM_NUMBER=



# Web push / PWA — run: npm run vapid:generate (or generate per-school in Admin → SMS & push)

VAPID_PUBLIC_KEY=

VAPID_PRIVATE_KEY=

VAPID_SUBJECT=mailto:admin@example.com



# Docker deploy

RUN_SEED=false

BACKUP_VIA_DOCKER=true
BACKUP_RETAIN_DAYS=30

