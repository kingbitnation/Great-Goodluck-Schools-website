# SchoolPilot — Caddy automatic HTTPS (alternative to nginx)
# Usage: caddy run --config deploy/Caddyfile

{
	email admin@schoolpilot.ng
}

app.schoolpilot.ng {
	encode gzip zstd
	header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	reverse_proxy localhost:3000
}

api.schoolpilot.ng {
	encode gzip zstd
	header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	reverse_proxy localhost:4000
}
