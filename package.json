{
  "name": "school-management-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:backend": "node src/backend/server.js",
    "dev:frontend": "npm run dev --prefix src/frontend",
    "dev:backend:ts": "ts-node-dev --respawn --transpile-only src/backend/app.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev --name init",
    "prisma:seed": "ts-node prisma/seed.ts",
    "db:setup": "npm run prisma:generate && npm run prisma:db:push && npm run prisma:seed",
    "prisma:db:push": "prisma db push"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.10.0"
  },
  "devDependencies": {
    "@prisma/client": "6.19.3",
    "@types/bcrypt": "^6.0.0",
    "prisma": "6.19.3",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
