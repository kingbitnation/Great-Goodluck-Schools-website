{
  "name": "school-management-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:backend": "node src/backend/server.js",
    "dev:frontend": "npm run dev --prefix src/frontend",
    "dev:backend:ts": "ts-node-dev --respawn --transpile-only src/backend/app.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev --name init",
    "prisma:seed": "ts-node prisma/seed.ts",
    "db:setup": "npm run prisma:generate && npm run prisma:db:push && npm run prisma:seed",
    "prisma:db:push": "prisma db push",
    "test": "node tests/run-node-tests.js tests/unit",
    "test:unit": "node tests/run-node-tests.js tests/unit",
    "test:penetration": "node --test tests/unit/penetrationFocus.test.js && node tests/require-backend.js && node --test tests/integration/penetration.test.js",
    "test:integration": "node tests/require-backend.js && node tests/run-node-tests.js tests/integration",
    "test:smoke": "node tests/health.test.js && node tests/integration.test.js",
    "test:all": "node tests/run-all.js",
    "test:coverage": "c8 --include=src/backend/lib/** --include=src/backend/middleware/** --reporter=text --reporter=html node tests/run-node-tests.js tests/unit",
    "test:e2e": "node tests/require-backend.js && playwright test --project=api",
    "test:e2e:ui": "node tests/require-backend.js && playwright test --project=chromium",
    "test:e2e:all": "node tests/require-backend.js && playwright test",
    "test:e2e:install": "playwright install chromium",
    "docker:up": "docker compose up -d",
    "docker:up:db": "docker compose up -d db",
    "docker:up:full": "docker compose --profile full up -d --build",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml -f docker-compose.local.yml --env-file .env.production up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "backup:db": "node scripts/backup-db.js",
    "backup:schedule": "node scripts/schedule-backup.js",
    "restore:db": "node scripts/restore-db.js",
    "platform:reset": "node scripts/reset-platform-data.js",
    "secrets:generate": "node scripts/generate-production-secrets.js",
    "vapid:generate": "node scripts/generate-vapid-keys.js",
    "deploy:preflight": "node scripts/production-preflight.js",
    "deploy:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml -f docker-compose.local.yml --env-file .env.production up -d --build",
    "health:monitor": "node scripts/health-monitor.js",
    "lighthouse": "node scripts/lighthouse-audit.js",
    "security:audit": "node scripts/security-audit.js && npm audit --production --audit-level=high",
    "test:e2e:staging": "node scripts/staging-e2e.js",
    "deploy:pipeline": "node scripts/deploy-pipeline.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^9.0.1",
    "otplib": "^13.4.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.10.0",
    "qrcode": "^1.5.4",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@prisma/client": "6.19.3",
    "@types/bcrypt": "^6.0.0",
    "c8": "^10.1.3",
    "prisma": "6.19.3",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "tar": "^7.5.16"
  }
}
