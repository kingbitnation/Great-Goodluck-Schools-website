# =============================================================================
# SchoolPilot — PRODUCTION environment template
# Copy to .env.production and fill every CHANGE_ME value.
# Generate secrets: npm run secrets:generate
# Launch guide: docs/LAUNCH_VERCEL_RAILWAY.md
# =============================================================================

# --- Core (required) ---
NODE_ENV=production
TRUST_PROXY=true

# Public URLs (replace with your domains)
APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_API_BASE_URL=https://your-api.up.railway.app
API_PUBLIC_URL=https://your-api.up.railway.app
BACKEND_URL=https://your-api.up.railway.app

# Neon PostgreSQL (use pooled URL for production if available)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
SKIP_DB_PUSH=true
RUN_SEED=false

# Auth secrets — MUST be unique, 32+ chars. Run: npm run secrets:generate
JWT_SECRET=CHANGE_ME_JWT_SECRET
REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
INTEGRATION_ENCRYPTION_KEY=CHANGE_ME_INTEGRATION_KEY

PORT=4000

# --- Platform bank (SaaS subscription manual transfers) ---
PLATFORM_BANK_NAME=OPay
PLATFORM_BANK_ACCOUNT_NAME=Your Business Name
PLATFORM_BANK_ACCOUNT_NUMBER=CHANGE_ME

# --- Email (Gmail App Password or SendGrid) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=CHANGE_ME_APP_PASSWORD
SMTP_FROM="SchoolPilot <your@gmail.com>"

# --- Cloudinary (recommended for uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
UPLOAD_MAX_BYTES=10485760

# --- Payments — platform SaaS + fallback for schools ---
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_HASH=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- AI (OpenRouter) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o
AI_MODEL=openai/gpt-4o
AI_MAX_TOKENS=2048

# --- SMS (Termii) ---
SMS_PROVIDER=termii
TERMII_API_KEY=
TERMII_SENDER_ID=

# --- Redis (optional — multi-instance queues/rate limits) ---
REDIS_URL=

# --- Web push (optional) — npm run vapid:generate ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@yourdomain.com

# --- Monitoring (optional) ---
HEALTH_CHECK_URL=https://your-api.up.railway.app/api/health/ready

# --- Vercel frontend (set in Vercel dashboard, not on Railway) ---
# BACKEND_URL=https://your-api.up.railway.app
# NEXT_PUBLIC_PLATFORM_BANK_NAME=
# NEXT_PUBLIC_PLATFORM_BANK_ACCOUNT_NAME=
# NEXT_PUBLIC_PLATFORM_BANK_ACCOUNT_NUMBER=
