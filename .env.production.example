# =============================================================================
# SchoolPilot — PRODUCTION environment template
# Copy to .env.production and fill every CHANGE_ME value.
# Generate secrets: npm run secrets:generate
# =============================================================================

# --- Core (required) ---
NODE_ENV=production
TRUST_PROXY=true

# Public URLs (replace with your domain)
APP_URL=https://app.schoolpilot.ng
NEXT_PUBLIC_API_BASE_URL=https://api.schoolpilot.ng
API_PUBLIC_URL=https://api.schoolpilot.ng

# Database — use a dedicated app user with least privilege (not postgres superuser)
# Example: postgresql://schoolpilot_app:STRONG_PASSWORD@db:5432/schooldb
DATABASE_URL=postgresql://schoolpilot_app:CHANGE_ME_DB_PASSWORD@db:5432/schooldb
POSTGRES_USER=schoolpilot_app
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=schooldb

# Auth secrets — MUST be unique, 32+ chars. Run: npm run secrets:generate
JWT_SECRET=CHANGE_ME_JWT_SECRET
REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET

PORT=4000
RUN_SEED=false

# --- Backups ---
BACKUP_VIA_DOCKER=true
BACKUP_RETAIN_DAYS=30

# --- Manual payments (SaaS subscription bank transfer) ---
PLATFORM_BANK_NAME=Zenith Bank
PLATFORM_BANK_ACCOUNT_NAME=SchoolPilot Ltd
PLATFORM_BANK_ACCOUNT_NUMBER=CHANGE_ME_ACCOUNT_NUMBER

# --- Email (required for transactional mail) ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=CHANGE_ME_SMTP
SMTP_FROM="SchoolPilot <noreply@schoolpilot.ng>"

# --- Cloud file uploads (recommended) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
UPLOAD_MAX_BYTES=10485760

# --- Redis (recommended for multi-instance rate limits) ---
REDIS_URL=redis://redis:6379

# --- AI (optional — demo mode without key) ---
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# --- SMS (optional) ---
SMS_PROVIDER=termii
TERMII_API_KEY=
TERMII_SENDER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Web push (optional) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@schoolpilot.ng

# --- Platform bank (manual subscription payments) ---
PLATFORM_BANK_NAME=Zenith Bank
PLATFORM_BANK_ACCOUNT_NAME=SchoolPilot Ltd
PLATFORM_BANK_ACCOUNT_NUMBER=CHANGE_ME

# --- Monitoring (optional) ---
HEALTH_CHECK_URL=https://api.schoolpilot.ng/api/health/ready
SLACK_WEBHOOK_URL=
